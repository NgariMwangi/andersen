# App branding
APP_NAME=Andersen
ENABLE_PAYROLL=false
ENABLE_ATTENDANCE=false
ENABLE_OVERTIME=false
ENABLE_BRANCHES=false
# Salary storage: annual (per annum, default) or monthly. Payroll divides annual by 12 when enabled.
SALARY_BASIS=annual
# Leave: set true only if unused days may roll into the next calendar year (default false).
# LEAVE_ALLOW_CARRY_FORWARD=false

# Flask
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
# Rate limiting (global + auth routes). Default off; set true to enable.
# RATELIMIT_ENABLED=false
# Signed-in session length in hours (default 2). Also applies to CSRF token lifetime.
# SESSION_LIFETIME_HOURS=2
# Set true only when users access the app over HTTPS. If false/missing and
# APP_BASE_URL is http://, session cookies work on plain HTTP (required for IP:port deploys).
# SESSION_COOKIE_SECURE=false

# Database (PostgreSQL 15+)
DATABASE_URL=postgresql://postgres:deno0707@localhost:5432/hrms_kenya

# Redis (optional, for sessions and Celery)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Mail (legacy Flask-Mail; optional)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@yourcompany.com

# Brevo — transactional email (password reset, leave notifications)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=hr@nexgenfuelworks.com
BREVO_SENDER_NAME=HR NexGen Fuelworks
APP_BASE_URL=https://hr.nexgenfuelworks.com
# Optional extra leave-alert inbox(es), comma-separated. By default alerts go to all
# active users with the HR Manager or HR Staff role.
# LEAVE_HR_NOTIFY_EMAIL=
PASSWORD_RESET_EXPIRY_SECONDS=3600

# File uploads (optional override; default 500 MB per file/request)
# UPLOAD_MAX_BYTES=524288000
# UPLOAD_FOLDER=/var/hrms/uploads
# Employee documents — folder *outside* the repo, sibling to andersen_hrms/
# Default (local): ../employeeuploads  e.g. Desktop/Andersen/employeeuploads
# EMPLOYEE_UPLOADS_ROOT=/path/to/employeeuploads
# EMPLOYEE_DOCUMENT_MAX_BYTES=524288000

# Logging
LOG_LEVEL=INFO
LOG_TO_STDOUT=false
LOG_DIR=logs

# Test database (for pytest)
# TEST_DATABASE_URL=postgresql://user:password@localhost:5432/hrms_kenya_test
