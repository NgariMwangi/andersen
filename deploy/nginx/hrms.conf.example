# Copy to Ubuntu, e.g. /etc/nginx/sites-available/hrms
# Then: sudo ln -sf /etc/nginx/sites-available/hrms /etc/nginx/sites-enabled/
#       sudo nginx -t && sudo systemctl reload nginx
#
# Required for uploads up to 500 MB (Flask MAX_CONTENT_LENGTH matches this).

server {
    listen 80;
    server_name hrms.example.com;

    # Must be >= Flask MAX_CONTENT_LENGTH (500M in config.py)
    client_max_body_size 500M;

    location / {
        proxy_pass http://127.0.0.1:5001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Large uploads can take a while
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }
}
